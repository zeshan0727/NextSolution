#!/bin/sh
set -e

mkdir -p /rootfs/var/mobile/Library/DailyLedgerSMSImport 2>/dev/null || true
chown mobile:mobile /rootfs/var/mobile/Library/DailyLedgerSMSImport 2>/dev/null || true
chmod 700 /rootfs/var/mobile/Library/DailyLedgerSMSImport 2>/dev/null || true

launchctl bootout system/com.nextsolution.dailyledger.smsimport 2>/dev/null || true
launchctl bootout gui/501/com.nextsolution.dailyledger.smsimport 2>/dev/null || true
launchctl bootstrap gui/501 /Library/LaunchAgents/com.nextsolution.dailyledger.smsimport.plist
launchctl kickstart -k gui/501/com.nextsolution.dailyledger.smsimport
launchctl print gui/501/com.nextsolution.dailyledger.smsimport >/dev/null

exit 0
